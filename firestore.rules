rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ---- Helper functions ----
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isAuthenticated() && request.auth.uid == uid;
    }

    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isAdmin() {
      return isAuthenticated() && getUserRole() == 'admin';
    }

    function isSeller() {
      return isAuthenticated() && getUserRole() == 'seller';
    }

    function isDriver() {
      return isAuthenticated() && getUserRole() == 'driver';
    }

    // ---- Users collection ----
    match /users/{uid} {
      // Sellers need to read driver user docs (name/phone) to show in the driver picker.
      allow read: if isOwner(uid) || isAdmin() || isSeller();
      // Users can create their own doc; admin can create docs for any user
      // (needed when admin creates driver/seller accounts)
      allow create: if isAuthenticated() && (request.auth.uid == uid || isAdmin());
      allow update: if isOwner(uid) || isAdmin();
      allow delete: if isAdmin();

      // Addresses subcollection — only the owner can read/write their own addresses
      match /addresses/{addressId} {
        allow read, write: if isOwner(uid);
      }
    }

    // ---- Seller profiles ----
    match /seller_profiles/{uid} {
      // Any authenticated user can read seller profiles
      // (customers need to read current rating before writing the new average)
      allow read: if isAuthenticated();
      allow create: if isOwner(uid) && isSeller();
      allow update: if isAdmin() || isOwner(uid) ||
        // Customers can update only the rating aggregate fields (from reviews)
        (isAuthenticated() &&
          request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['rating', 'totalReviews']));
      allow delete: if isAdmin();
    }

    // ---- Driver profiles ----
    match /driver_profiles/{uid} {
      // Any authenticated user can read driver profiles
      // (customers need to read current rating before writing the new average)
      allow get: if isAuthenticated();
      allow list: if isAuthenticated();
      allow create: if isAdmin() || isSeller();
      allow update: if isOwner(uid) || isAdmin() || isSeller() ||
        // Customers can update only the rating field (from reviews)
        (isAuthenticated() &&
          request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['rating']));
      allow delete: if isAdmin();
    }

    // ---- Products ----
    match /products/{productId} {
      // Any authenticated user can read available products
      allow read: if isAuthenticated() || true; // public reads OK for catalog
      // Sellers with the seller role can create their own products; admins can create any
      allow create: if isAdmin() ||
        (isSeller() && request.resource.data.sellerId == request.auth.uid);
      // Sellers can only update their own products; admins can update any
      // Customers can update only rating/reviewCount fields (from product reviews)
      allow update: if isAdmin() ||
        (isSeller() && resource.data.sellerId == request.auth.uid) ||
        (isAuthenticated() &&
          request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['rating', 'reviewCount'])) ||
        // Customers decrement stock when placing an order (via transaction)
        (isAuthenticated() &&
          request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['stock']) &&
          request.resource.data.stock < resource.data.stock &&
          request.resource.data.stock >= 0);
      allow delete: if isAdmin() ||
        (isSeller() && resource.data.sellerId == request.auth.uid);
    }

    // ---- Orders ----
    match /orders/{orderId} {
      // Single-document reads: verify caller is a party to the order.
      // resource.data is available for get (single doc) so OR conditions work fine.
      allow get: if isAdmin() ||
        (isAuthenticated() && (
          resource.data.customerId == request.auth.uid ||
          request.auth.uid in resource.data.sellerIds ||
          resource.data.driverId == request.auth.uid
        ));

      // Collection queries (list): allow any authenticated user.
      // Firestore cannot evaluate OR-chained resource.data conditions at query
      // time, so we trust the client's .where() constraints to scope results.
      // Real data isolation is enforced by the get rule above.
      allow list: if isAuthenticated();

      // Customers create orders
      allow create: if isAuthenticated() &&
        request.resource.data.customerId == request.auth.uid;

      // Updates:
      // - Customer: cancel own order only (limited fields)
      // - Seller: update status/driver fields for their orders
      // - Driver: update their delivery status fields
      // - Admin: full access
      allow update: if isAdmin() ||
        (isAuthenticated() && resource.data.customerId == request.auth.uid) ||
        (isSeller() && request.auth.uid in resource.data.sellerIds) ||
        (isDriver() && resource.data.driverId == request.auth.uid);

      allow delete: if isAdmin();
    }

    // ---- Reviews ----
    match /reviews/{reviewId} {
      allow read: if true; // public
      allow create: if isAuthenticated() &&
        request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() &&
        resource.data.userId == request.auth.uid;
      allow delete: if isAdmin() ||
        (isAuthenticated() && resource.data.userId == request.auth.uid);
    }

    // ---- Notifications ----
    match /notifications/{notifId} {
      // Single-doc read: enforce ownership
      allow get: if isAuthenticated() && resource.data.userId == request.auth.uid;
      // List query: allow authenticated users (client always queries by userId)
      allow list: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() &&
        resource.data.userId == request.auth.uid;
      allow delete: if isAdmin() ||
        (isAuthenticated() && resource.data.userId == request.auth.uid);
    }

    // ---- Promo codes ----
    match /promo_codes/{code} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // ---- Audit logs ----
    match /audit_logs/{logId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated();
      allow update, delete: if false; // immutable
    }

    // ---- Platform settings ----
    match /platform_settings/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
  }
}
